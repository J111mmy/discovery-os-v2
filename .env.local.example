# ============================================================
# Discovery OS v2 — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase ---
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, bypasses RLS
# NEVER expose this to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- LLM Providers ---
# Anthropic (primary — compose drafts, summaries, verification)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings only — text-embedding-3-small)
OPENAI_API_KEY=sk-...

# --- Ingest extraction tuning ---
# Optional. Defaults: standard tier, 8 units per LLM call, 4 calls in parallel.
# Keep INGEST_EXTRACTION_TIER on standard unless a reviewed model-routing change says otherwise.
INGEST_EXTRACTION_TIER=standard
INGEST_EXTRACTION_BATCH_SIZE=8
INGEST_EXTRACTION_PARALLELISM=4
INGEST_EXTRACTION_TIMEOUT_MS=180000
INGEST_EXTRACTION_MAX_OUTPUT_TOKENS=8192

# --- Inngest ---
# Found in: Inngest Dashboard → Project → Keys
INNGEST_EVENT_KEY=your-event-key-here
INNGEST_SIGNING_KEY=signkey-prod-...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Public Access Request Protection ---
# Secret key from Cloudflare Turnstile. Server-side only.
TURNSTILE_SECRET_KEY=0x...

# --- Transactional Email ---
# Used for app-sent invite emails. Configure the same values in Vercel.
RESEND_API_KEY=re_...
EMAIL_FROM="DiscOS <invites@your-domain.com>"
