# ============================================================
# Discovery OS v2 — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase ---
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, bypasses RLS
# NEVER expose this to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- LLM Providers ---
# Anthropic (primary — compose drafts, summaries, verification)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings only — text-embedding-3-small)
OPENAI_API_KEY=sk-...

# --- Inngest ---
# Found in: Inngest Dashboard → Project → Keys
INNGEST_EVENT_KEY=your-event-key-here
INNGEST_SIGNING_KEY=signkey-prod-...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
